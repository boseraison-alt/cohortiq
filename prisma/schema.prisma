generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users (email/password, invite-only) ──
model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String?
  password        String
  role            String        @default("user")
  createdAt       DateTime      @default(now())
  invitedBy       String?
  lastSeen        DateTime?
  creditsGranted  Float         @default(10.0)  // USD allocated by admin
  prefIndustry    String?       // e.g. "Healthcare", "Tech/SaaS", "Finance"
  prefExamples    String?       // "maximize_examples" | "balanced" | "maximize_text"
  prefLevel       String?       // "5yo" | "highschool" | "manager" | "csuite" | "phd"
  prefFont        String?       // null | "opendyslexic"
  prefReadingMode String?       // null | "focused"
  courses         Course[]
  performance     Performance[]
  usageLogs       UsageLog[]
  approvals       Material[]    @relation("ApprovedBy")
  chatSessions    ChatSession[]
  sentMessages    DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")
  resetTokens     PasswordResetToken[]
  brainSearches   BrainSearchHistory[]
}

// ── Password Reset Tokens ──
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ── Invite system ──
model Invite {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  usedAt    DateTime?
  createdBy String   // admin user ID
  createdAt DateTime @default(now())
  expiresAt DateTime // 7 days from creation

  @@index([token])
  @@index([email])
}

// ── Cost / Usage tracking ──
model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  courseId      String?
  action       String   // "qa", "practice", "grade", "podcast_script", "podcast_audio", "flashcards"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  ttsChars     Int      @default(0)
  costUsd      Float    @default(0)
  metadata     String?  // JSON string for extra details
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([createdAt])
}

// ── App Models ──
model Course {
  id          String        @id @default(cuid())
  name        String
  color       String        @default("#C9956B")
  userId      String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks       Week[]
  materials   Material[]
  chunks      Chunk[]
  flashcards    Flashcard[]
  performance   Performance[]
  podcasts      Podcast[]
  chatSessions  ChatSession[]
  videos        Video[]

  @@index([userId])
}

model Week {
  id        String     @id @default(cuid())
  courseId   String
  number    Int
  label     String?
  createdAt DateTime   @default(now())
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials Material[]

  @@unique([courseId, number])
  @@index([courseId])
}

model Material {
  id           String    @id @default(cuid())
  courseId      String
  weekId       String?
  title        String
  content      String    @db.Text
  wordCount    Int       @default(0)
  sourceType   String    @default("pasted")
  status       String    @default("pending") // "pending" | "approved" | "rejected"
  rejectedNote String?   // reason for rejection
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  week         Week?     @relation(fields: [weekId], references: [id], onDelete: SetNull)
  approvedBy   User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  chunks       Chunk[]

  @@index([courseId])
  @@index([weekId])
  @@index([status])
}

model Chunk {
  id         String   @id @default(cuid())
  courseId    String
  materialId String
  title      String
  text       String   @db.Text
  chunkIndex Int
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([materialId])
}

model Flashcard {
  id        String            @id @default(cuid())
  courseId   String
  front     String            @db.Text
  back      String            @db.Text
  topic     String?
  createdAt DateTime          @default(now())
  course    Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviews   FlashcardReview[]

  @@index([courseId])
}

model FlashcardReview {
  id           String    @id @default(cuid())
  flashcardId  String
  userId       String
  nextReviewAt DateTime  @default(now())
  interval     Int       @default(1)      // days until next review
  easeFactor   Float     @default(2.5)    // SM-2 E-factor
  repetitions  Int       @default(0)      // consecutive correct answers
  lastRating   Int?                       // 0=forgot, 1=hard, 2=good, 3=easy
  updatedAt    DateTime  @updatedAt
  flashcard    Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([flashcardId, userId])
  @@index([userId, nextReviewAt])
  @@index([flashcardId])
}

model Performance {
  id        String   @id @default(cuid())
  courseId   String
  userId    String
  topic     String
  question  String
  correct   Boolean
  score     String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
  @@index([courseId, topic])
}

model Podcast {
  id        String   @id @default(cuid())
  courseId  String
  userId    String?
  duration  Int
  topic     String?
  script    Json
  audioUrl  String?  // saved MP3 file path e.g. /uploads/podcasts/xxx.mp3
  weekIds   String?
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
  @@index([courseId, userId])
}

// ── Videos (external links + uploaded files) ──
model Video {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  url         String   // external URL or /uploads/videos/filename
  sourceType  String   @default("url") // "url" | "file"
  fileName    String?  // original filename for display/download
  fileSize    Int?     // bytes
  lang        String   @default("en") // language code: "en" | "ja" | "es" | "fr" | "zh"
  slidesData  String?  // JSON array of slide data with per-slide durations
  createdAt   DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([courseId, lang])
}

// ── Chat (persistent conversations) ──
model ChatSession {
  id        String        @id @default(cuid())
  courseId   String
  userId    String
  title     String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt])
  @@index([courseId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String      // "user" | "assistant"
  content   String      @db.Text
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ── Content Ratings (thumbs up/down for podcasts & videos) ──
model ContentRating {
  id           String   @id @default(cuid())
  userId       String
  courseId     String
  contentType  String   // "podcast" | "video"
  contentId    String   // podcast.id or video.id
  contentTitle String?
  rating       String   // "up" | "down"
  feedback     String?  @db.Text
  savedForLater Boolean @default(false)
  createdAt    DateTime @default(now())

  @@unique([userId, contentType, contentId])
  @@index([courseId])
  @@index([contentType])
  @@index([createdAt])
}

// ── Direct Messages (user-to-user chat) ──
model DirectMessage {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  content    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  from       User     @relation("SentMessages",     fields: [fromUserId], references: [id], onDelete: Cascade)
  to         User     @relation("ReceivedMessages",  fields: [toUserId],   references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@index([toUserId])
  @@index([toUserId, read])
  @@index([fromUserId, toUserId, createdAt])
}

// ── Brain Search History ──
model BrainSearchHistory {
  id        String   @id @default(cuid())
  userId    String
  question  String   @db.Text
  answer    String   @db.Text
  sources   String?  @db.Text  // JSON array of {courseName, color}
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
