# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth
NEXTAUTH_URL=https://your-app.railway.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# External video generation (optional — only needed for Rich Animated Video feature)
# X-Pilot — technical/formula-heavy content:     https://x-pilot.ai
XPILOT_API_KEY=
# HeyGen — instructor-led talking-head videos:   https://heygen.com
HEYGEN_API_KEY=
# Runway — creative/cinematic content:           https://runwayml.com  (not yet wired up)
RUNWAY_API_KEY=
